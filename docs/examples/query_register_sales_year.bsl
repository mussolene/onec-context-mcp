// Запрос к регистру накопления "Выручка и себестоимость продаж" (продажи)
// для получения итогов на конец года в 1С:Бухгалтерия предприятия 3.0
//
// Регистр оборотный — остатки не ведутся, используем виртуальную таблицу Обороты
// с периодичностью Год. Имя регистра в типовой БП 3.0: ВыручкаИСебестоимостьПродаж.
// Если в вашей конфигурации регистр называется иначе (например, Продажи) —
// замените имя в тексте запроса.
//
// Имена измерений и ресурсов (Организация, Номенклатура, СуммаВыручкиОборот и т.д.)
// могут отличаться в разных редакциях — при ошибке проверьте метаданные регистра.

// Итоги за год в разрезе организаций (и при необходимости номенклатуры/номенклатурной группы).
// Периодичность ГОД даёт один срез на весь год.
Функция ПолучитьИтогиПродажНаКонецГода(Год, Организация = Неопределено) Экспорт

	НачалоГода = НачалоМесяца(Дата(Год, 1, 1));
	КонецГода = КонецДня(Дата(Год, 12, 31));

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОборотыПродаж.Организация КАК Организация,
	|	ОборотыПродаж.Номенклатура КАК Номенклатура,
	|	ОборотыПродаж.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
	|	ОборотыПродаж.СуммаВыручкиОборот КАК СуммаВыручки,
	|	ОборотыПродаж.СуммаСебестоимостиОборот КАК СуммаСебестоимости,
	|	ОборотыПродаж.КоличествоОборот КАК Количество
	|ИЗ
	|	РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(
	|			&НачалоГода,
	|			&КонецГода,
	|			ГОД,
	|			Организация = &Организация) КАК ОборотыПродаж";

	Запрос.УстановитьПараметр("НачалоГода", НачалоГода);
	Запрос.УстановитьПараметр("КонецГода", КонецГода);
	Если ЗначениеЗаполнено(Организация) Тогда
		Запрос.УстановитьПараметр("Организация", Организация);
	Иначе
		// Убираем отбор по организации — итоги по всем
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ОборотыПродаж.Организация КАК Организация,
		|	ОборотыПродаж.Номенклатура КАК Номенклатура,
		|	ОборотыПродаж.НоменклатурнаяГруппа КАК НоменклатурнаяГруппа,
		|	ОборотыПродаж.СуммаВыручкиОборот КАК СуммаВыручки,
		|	ОборотыПродаж.СуммаСебестоимостиОборот КАК СуммаСебестоимости,
		|	ОборотыПродаж.КоличествоОборот КАК Количество
		|ИЗ
		|	РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(
		|			&НачалоГода,
		|			&КонецГода,
		|			ГОД) КАК ОборотыПродаж";
	КонецЕсли;

	Возврат Запрос.Выполнить();

КонецФункции

// Сводные итоги за год по организациям (без детализации по номенклатуре)
Функция ПолучитьИтогиПродажЗаГодСводные(Год, Организация = Неопределено) Экспорт

	НачалоГода = НачалоМесяца(Дата(Год, 1, 1));
	КонецГода = КонецДня(Дата(Год, 12, 31));

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОборотыПродаж.Организация КАК Организация,
	|	СУММА(ОборотыПродаж.СуммаВыручкиОборот) КАК СуммаВыручки,
	|	СУММА(ОборотыПродаж.СуммаСебестоимостиОборот) КАК СуммаСебестоимости,
	|	СУММА(ОборотыПродаж.КоличествоОборот) КАК Количество
	|ИЗ
	|	РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(
	|			&НачалоГода,
	|			&КонецГода,
	|			ГОД,
	|			Организация = &Организация) КАК ОборотыПродаж
	|СГРУППИРОВАТЬ ПО
	|	ОборотыПродаж.Организация";

	Запрос.УстановитьПараметр("НачалоГода", НачалоГода);
	Запрос.УстановитьПараметр("КонецГода", КонецГода);
	Если ЗначениеЗаполнено(Организация) Тогда
		Запрос.УстановитьПараметр("Организация", Организация);
	Иначе
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ОборотыПродаж.Организация КАК Организация,
		|	СУММА(ОборотыПродаж.СуммаВыручкиОборот) КАК СуммаВыручки,
		|	СУММА(ОборотыПродаж.СуммаСебестоимостиОборот) КАК СуммаСебестоимости,
		|	СУММА(ОборотыПродаж.КоличествоОборот) КАК Количество
		|ИЗ
		|	РегистрНакопления.ВыручкаИСебестоимостьПродаж.Обороты(
		|			&НачалоГода,
		|			&КонецГода,
		|			ГОД) КАК ОборотыПродаж
		|СГРУППИРОВАТЬ ПО
		|	ОборотыПродаж.Организация";
	КонецЕсли;

	Возврат Запрос.Выполнить();

КонецФункции

// Пример вызова и вывода результата (для консоли или обработки)
Процедура ПримерИспользования() Экспорт

	Год = 2024;

	// Итоги на конец года (обороты за год) по каждой номенклатуре
	Результат = ПолучитьИтогиПродажНаКонецГода(Год);
	Для Каждого Строка Из Результат.Выгрузить() Цикл
		Сообщить(Строка.Организация, " | ", Строка.Номенклатура, " | Выручка: ", Строка.СуммаВыручки, " | Себестоимость: ", Строка.СуммаСебестоимости);
	КонецЦикла;

	// Сводные итоги за год по организациям
	РезультатСвод = ПолучитьИтогиПродажЗаГодСводные(Год);
	Для Каждого Строка Из РезультатСвод.Выгрузить() Цикл
		Сообщить(Строка.Организация, " | Выручка за год: ", Строка.СуммаВыручки, " | Себестоимость: ", Строка.СуммаСебестоимости);
	КонецЦикла;

КонецПроцедуры
