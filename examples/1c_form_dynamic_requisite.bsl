// Пример: добавить реквизит на форму программно, отобразить и повесить действие
// Вызывать из ПриСозданииНаСервере или по кнопке

&НаСервере
Процедура ДобавитьРеквизитИЭлементНаФорму()
	// 1. Добавить реквизит формы (через ИзменитьРеквизиты)
	ДобавляемыеРеквизиты = Новый Массив;
	НовыйРеквизит = Новый РеквизитФормы("МойРеквизит", Новый ОписаниеТипов("Строка", Новый КвалификаторыСтроки(100)));
	ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);
	ИзменитьРеквизиты(ДобавляемыеРеквизиты);

	// 2. Добавить элемент (поле ввода) и привязать к реквизиту
	ГруппаФормы = Элементы.Добавить("ГруппаДобавленных", Тип("ГруппаФормы"));
	ГруппаФормы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаФормы.Заголовок = "Добавлено программно";

	НовыйЭлемент = Элементы.Добавить("ПолеМойРеквизит", Тип("ПолеФормы"));
	НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным = "МойРеквизит";
	НовыйЭлемент.Родитель = ГруппаФормы;

	// 3. Добавить кнопку и команду
	НоваяКоманда = Команды.Добавить("МояКоманда", "Выполнить действие");
	НоваяКоманда.Действие = "ВыполнитьМоеДействие";

	НоваяКнопка = Элементы.Добавить("КнопкаМояКоманда", Тип("КнопкаФормы"));
	НоваяКнопка.ИмяКоманды = "МояКоманда";
	НоваяКнопка.Родитель = ГруппаФормы;
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьМоеДействие(Команда)
	Сообщить("Значение реквизита: " + МойРеквизит);
КонецПроцедуры
