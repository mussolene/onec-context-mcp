// Пример: фоновое задание — передать Структуру и получить результат на клиенте
// Клиент: запуск + обработка результата

&НаКлиенте
Процедура ЗапуститьФоновоеЗадание(Команда)
	Параметры = Новый Структура;
	Параметры.Вставить("ИмяДанных", "Тест");
	Параметры.Вставить("Количество", 42);

	Оповещение = Новый ОписаниеОповещения("ПослеВыполненияНаСервере", ЭтотОбъект, Параметры);

	ФоновоеЗаданиеКлиентСервер.Выполнить(
		"ВыполнитьДлительнуюОперациюНаСервере",
		Параметры,
		Оповещение
	);
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыполненияНаСервере(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Сообщить("Ошибка выполнения");
		Возврат;
	КонецЕсли;

	// Результат — Структура, переданная с сервера
	Сообщить("Результат: " + Результат.РезультатОперации);
КонецПроцедуры

// Сервер: метод, вызываемый в фоне
&НаСервере
Функция ВыполнитьДлительнуюОперациюНаСервере(Параметры)
	// Параметры — та же Структура, что передали с клиента
	Результат = Новый Структура("РезультатОперации", "Выполнено: " + Параметры.ИмяДанных + ", " + Параметры.Количество);
	Возврат Результат;
КонецФункции
