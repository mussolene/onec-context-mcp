# 1C Help — переменные окружения
# Скопируйте в .env и задайте значения под своё окружение.
# Не коммитьте .env в репозиторий.
#
# --- Быстрый старт (минимум для работы из коробки) ---
# Локально: QDRANT_HOST, QDRANT_PORT — если Qdrant не на localhost:6333.
# Docker: make up уже подставляет свои значения; при необходимости задайте HELP_SOURCE_BASE.
# HELP_PATH по умолчанию data (или каталог, переданный в mcp); в Docker MCP использует /data (→ ./data/unpacked).

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=onec_help
# Путь к каталогу хранилища Qdrant (для dashboard). В Docker: /qdrant_storage (→ ./data/qdrant)
# QDRANT_STORAGE_PATH=/qdrant_storage

# --- Пути к справке ---
# Базовый каталог для MCP (get_1c_help_topic с диска). По умолчанию: data (от cwd). В Docker: /data (→ ./data/unpacked).
# HELP_PATH=data
# Корень каталогов с версиями 1С для ingest (подпапки = версии, внутри — .hbk). Windows: HELP_SOURCE_BASE=C:/Program Files/1cv8
# Устаревший алиас (поддерживается в коде): HELP_SOURCES_DIR
HELP_SOURCE_BASE=/opt/1cv8

# Список путей через запятую (если не используете HELP_SOURCE_BASE)
# HELP_SOURCE_DIRS=/path/8.3.27,/path/8.3.26

# Языки справки для ingest (ru, en и т.д.)
HELP_LANGUAGES=ru

# Кодировка при чтении файлов справки: по умолчанию UTF-8, затем CP1251. Если вся справка в 1251 — задайте cp1251
# HELP_FILE_ENCODING=

# Макс. размер HTML (байты). Файлы больше — пропускаются (BeautifulSoup может виснуть на огромных). По умолчанию 10 MB.
# HELP_HTML_MAX_BYTES=10485760

# Таймаут 7z/unzip (секунды). По умолчанию 1800 (30 мин).
# UNPACK_TIMEOUT=1800

# Корень данных проекта. По умолчанию data. От него: BM25 vocab, маркеры ingest, по умолчанию DATA_UNPACKED_DIR=DATA_DIR/unpacked, INGEST_CACHE_FILE=DATA_DIR/ingest_cache/ingest_cache.db.
# DATA_DIR=data
# Каталог распакованной справки (по умолчанию DATA_DIR/unpacked).
# DATA_UNPACKED_DIR=data/unpacked
# INGEST_USE_TEMP=1 — временная папка с удалением после индексации (старый режим).
# HELP_INGEST_TEMP — каталог при INGEST_USE_TEMP=1 (по умолчанию $TMPDIR/help_ingest)
# HELP_INGEST_TEMP=/tmp/help_ingest

# Кэш ingest и статус — только Redis (SQLite для кэша не используется).
# REDIS_URL или REDIS_HOST обязательны при запуске ingest-worker и mcp.
# INGEST_CACHE_FILE — путь к файлу, чья родительская папка используется для маркеров (load_*.running и т.д.); по умолчанию DATA_DIR/ingest_cache/ingest_cache.db. Данные кэша в Redis.
# REDIS_URL=redis://localhost:6379/0
# REDIS_HOST=localhost  # если REDIS_URL не задан
# INGEST_MAX_WORKERS=4  # параллельных задач при ingest из data/unpacked (dashboard: Active: N tasks)
# Полная переиндексация без кэша: INGEST_SKIP_CACHE=1 или ingest --no-cache

# --- Эмбеддинги (ingest и поиск в MCP) ---
# Как пользоваться: 1) Установить Ollama, выполнить: ollama pull nomic-embed-text-v2-moe
# 2) Запускать проект как обычно (make up, make ingest-up) — переменные не нужны.
# Локально: Ollama на localhost:11434. В Docker: контейнеры идут на host.docker.internal:11434 (Ollama на хосте).
# LM Studio или local — задать в .env (пресеты ниже).
#
# По умолчанию: Ollama (localhost:11434), модель nomic-embed-text-v2-moe (768).
# Бэкенд: openai_api (по умолчанию, Ollama), local (HuggingFace), deterministic, none
# EMBEDDING_BACKEND=openai_api

# Модель: по умолчанию nomic-embed-text-v2-moe (Ollama). Для local — HuggingFace id nomic-ai/nomic-embed-text-v2-moe
# EMBEDDING_MODEL=nomic-embed-text-v2-moe

# URL API эмбеддингов: по умолчанию Ollama 11434; в контейнере — host.docker.internal:11434
# EMBEDDING_API_URL=http://localhost:11434/v1
# EMBEDDING_API_KEY=
# Размерность по умолчанию 768 (nomic-embed). Задаётся авто по модели/API или из коллекции Qdrant.
# EMBEDDING_DIMENSION=768

# --- Пресет: LM Studio вместо Ollama ---
# EMBEDDING_API_URL=http://localhost:1234/v1
# EMBEDDING_MODEL=nomic-embed-text-v2-moe
# EMBEDDING_DIMENSION=768

# --- Пресет: local (sentence-transformers, без Ollama/LM Studio) ---
# EMBEDDING_BACKEND=local
# EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v2-moe

# По умолчанию: батч 32, воркеры 2, таймаут 90 с (под LM Studio / внешний API). Для быстрого local можно увеличить.
# Размер батча для эмбеддингов (текстов за один вызов encode/API).
# EMBEDDING_BATCH_SIZE=32
# Число параллельных запросов к внешнему API (только openai_api).
# EMBEDDING_WORKERS=2
# Максимальная мощность: 1/true/yes — макс. батч (256) и воркеры (16).
# EMBEDDING_FORCE_BATCH=0
# Макс. одновременных запросов к API (семафор). При перегрузке LM Studio уменьшить.
# EMBEDDING_MAX_CONCURRENT=8
# Таймаут HTTP-запроса к API эмбеддингов (секунды). По умолчанию 90.
# EMBEDDING_TIMEOUT=90
# Таймаут для batch-запроса (секунды). По умолчанию — max(EMBEDDING_TIMEOUT, 30 + batch_size/10).
# EMBEDDING_BATCH_TIMEOUT=120
# Кэш эмбеддингов по хэшу текста (local/openai_api). 0 — отключён. Снижает повторные отправки в API при повторных ingest/load-snippets.
# EMBEDDING_CACHE_SIZE=10000

# BM25 sparse vectors для keyword-поиска (по умолчанию 1). 0 — отключить. add-bm25 — миграция без re-ingest.
# BM25_ENABLED=1
# BM25 стемминг (Snowball Russian): 1 — включён по умолчанию. 0 — точное совпадение токенов. Смена требует make add-bm25.
# BM25_STEMMING=1

# Файл для списка неудачных .hbk при ingest (опционально)
# INGEST_FAILED_LOG=/var/log/ingest_failed.log

# Как часто обновлять статус ingest в Redis (секунды). По умолчанию 2.
# INDEX_STATUS_INTERVAL_SEC=2

# Отключить debug даже при --debug (безопасность в проде)
# PRODUCTION=1

# --- Сниппеты (load-snippets, parse-fastcode, parse-helpf) ---
# Docker: ./data/snippets → /data/snippets. parse-fastcode/parse-helpf пишут туда.
# Локально: data/snippets/ или SNIPPETS_DIR.
# По умолчанию в Docker: SAVE_SNIPPET_TO_FILES=1, SNIPPETS_DIR=/data/snippets
SAVE_SNIPPET_TO_FILES=1
SNIPPETS_DIR=/data/snippets

# --- Стандарты (load-standards) ---
# По умолчанию загружаются оба репо. Docker: ./data/standards → /data/standards.
# STANDARDS_REPOS=1C-Company/v8-code-style:master,zeegin/v8std:main
# STANDARDS_SUBPATH=docs
# STANDARDS_DIR=/data/standards
# Дополнительно загружать стандарты с ITS v8std (https://its.1c.ru/db/v8std). Требует подписки ИТС.
# STANDARDS_ITS_V8STD=0
# ITS_AUTH_COOKIE=session_id=...   # куки после входа на its.1c.ru (если нужен доступ к контенту)
# ITS_V8STD_DELAY=0.5               # пауза между запросами (сек)
# ITS_V8STD_MAX_CONTENT=            # не задано или 0 = все статьи без лимита
# ITS_V8STD_MAX_BROWSE_PAGES=0      # 0 = все страницы оглавления (по умолчанию без лимита)

# --- Память (MCP, при MEMORY_ENABLED=1) ---
# По умолчанию в Docker: MEMORY_ENABLED=1
MEMORY_ENABLED=1
# MEMORY_BASE_PATH=~/.onec_help
# MEMORY_SHORT_LIMIT=50
# MEMORY_MEDIUM_LIMIT=500
# MEMORY_MEDIUM_TTL_DAYS=7

# --- Watchdog (мониторинг .hbk, STANDARDS_DIR, SNIPPETS_DIR; pending memory). По умолчанию включён (1). ---
# WATCHDOG_ENABLED=0
# WATCHDOG_POLL_INTERVAL=600
# WATCHDOG_PENDING_INTERVAL=600

# --- BSL LS (bsl-bridge) ---
# Проект в volume .:/projects. BSL_WORKSPACE_ROOT — путь к конфигу внутри контейнера (например /projects или /projects/src)
# BSL_HOST_PROJECTS_ROOT — подставляется через make up (pwd)
# BSL_WORKSPACE_ROOT=/projects
# BSL_CONTAINER_MEMORY=4g
# BSL_LS_VERSION=latest
# MCP_LSP_BSL_JAVA_XMX=2g
# MCP_LSP_BSL_JAVA_XMS=512m

# --- MCP ---
# Транспорт: stdio (локально), http или streamable-http (в Docker, для Cursor рекомендуется streamable-http)
# По умолчанию: streamable-http — для удалённого доступа (Docker, Cursor по URL)
MCP_TRANSPORT=streamable-http
# Хост: при запуске через CLI (python -m onec_help mcp) по умолчанию 127.0.0.1;
# при прямом запуске MCP-сервера (Docker: python -m onec_help.mcp_server) по умолчанию 0.0.0.0. Задайте при необходимости.
MCP_HOST=127.0.0.1
MCP_PORT=8050
MCP_PATH=/mcp
# Лимит запросов в минуту (120 по умолчанию). 0 — отключить
# MCP_RATE_LIMIT_PER_MIN=120
# Макс. символов сниппета в результатах поиска (по умолчанию 1200)
# MCP_SNIPPET_MAX_CHARS=1200
# Макс. символов топика в get_1c_code_answer/search_with_content (по умолчанию 4000)
# MCP_MAX_TOPIC_CHARS=4000
