data/
.env
.env.*
*.db
*.sqlite

# Docker and CI
Dockerfile*
docker-compose*.yml
.dockerignore
.github/
Makefile

# BSL bridge (separate image)
deps/

# Build artifacts
dist/
build/
*.egg-info/
*.egg
